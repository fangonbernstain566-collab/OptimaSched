generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  
}

model Role {
  id    String   @id @default(uuid())
  name  RoleName @unique
  users User[]
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  firstName    String
  lastName     String
  roleId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  auditLogs    AuditLog[]
  teacher      Teacher?
  settings     UserSettings?
  payments     Payment[]
  reviewedRequests ScheduleRequest[]
  notifications Notification[]
  role         Role          @relation(fields: [roleId], references: [id])
}

model Payment {
  id          String        @id @default(uuid())
  studentName String
  studentId   String
  amount      Float
  type        PaymentType
  method      PaymentMethod
  status      PaymentStatus @default(CONFIRMED)
  notes       String?
  cashierId   String
  cashier     User          @relation(fields: [cashierId], references: [id])
  isDeleted   Boolean       @default(false)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([createdAt])
  @@index([cashierId])
  @@index([status])
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Accessibility
  themeMode     ThemeMode @default(LIGHT)
  fontSize      FontSize  @default(MEDIUM)
  highContrast  Boolean   @default(false)
  reducedMotion Boolean   @default(false)

  // Common / general
  emailNotifications Boolean @default(true)
  inAppNotifications Boolean @default(true)
  defaultLandingPage String  @default("/dashboard")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model College {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique
  departments Department[]
}

model Department {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  collegeId String
  college   College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  teachers  Teacher[]
}

model Teacher {
  id              String         @id @default(uuid())
  userId          String         @unique
  departmentId    String
  maxTeachingLoad Int            @default(21)
  // Free-form credential tags (e.g. "Masters in IT", "LET Passer") the teacher
  // holds. Matched against Subject.requiredCredentials before assignment.
  credentials     String[]       @default([])
  isDeleted       Boolean        @default(false)
  deletedAt       DateTime?
  availabilities  Availability[]
  schedules       Schedule[]
  scheduleRequests ScheduleRequest[]
  department      Department     @relation(fields: [departmentId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Availability {
  id        String  @id @default(uuid())
  teacherId String
  dayOfWeek String
  startTime String
  endTime   String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Building {
  id    String @id @default(uuid())
  name  String @unique
  rooms Room[]
}

model Room {
  id         String     @id @default(uuid())
  name       String
  capacity   Int
  type       RoomType   @default(LECTURE_ROOM)
  buildingId String
  isDeleted  Boolean    @default(false)
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  building   Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  schedules  Schedule[]
  scheduleRequests ScheduleRequest[]
}

model Subject {
  id                  String              @id @default(uuid())
  code                String              @unique
  name                String
  units               Int
  isLabRequired       Boolean             @default(false)
  // Credential tags a teacher must ALL possess (matched against
  // Teacher.credentials) before they can be assigned to this subject.
  // Empty means no special credential is required.
  requiredCredentials String[]            @default([])
  offerings           SubjectOffering[]
  curriculumSubjects  CurriculumSubject[]
}

model SubjectOffering {
  id        String     @id @default(uuid())
  subjectId String
  classCode String     @unique
  schedules Schedule[]
  scheduleRequests ScheduleRequest[]
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Section {
  id        String     @id @default(uuid())
  name      String     @unique
  program   String
  yearLevel Int
  schedules Schedule[]
  scheduleRequests ScheduleRequest[]
}

// Maps which subjects belong to a given program + year level curriculum.
// Kept separate from Subject because gen-ed subjects (e.g. NSTP, PE) are
// shared across multiple programs/year levels, not exclusive to one.
model CurriculumSubject {
  id        String  @id @default(uuid())
  program   String
  yearLevel Int
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([program, yearLevel, subjectId])
}

model SchoolYear {
  id        String     @id @default(uuid())
  name      String     @unique
  isCurrent Boolean    @default(false)
  schedules Schedule[]
}

model AuditLog {
  id               String   @id @default(uuid())
  userId           String?
  userName         String?
  userRole         String?
  action           String
  module           String
  description      String
  targetRecordId   String?
  targetRecordName String?
  ipAddress        String?
  userAgent        String?
  metadata         Json?
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([module, createdAt])
  @@index([action, createdAt])
  @@index([userRole, createdAt])
  @@index([targetRecordId])
}

model Semester {
  id        String     @id @default(uuid())
  name      String
  isCurrent Boolean    @default(false)
  schedules Schedule[]
}

model Schedule {
  id                String          @id @default(uuid())
  teacherId         String
  roomId            String
  sectionId         String
  subjectOfferingId String
  schoolYearId      String
  semesterId        String
  dayOfWeek         String
  startTime         String
  enrolledStudents String[] @default([])
  endTime           String
  studentCount      Int             @default(0)
  status            ScheduleStatus  @default(PENDING)
  isDeleted         Boolean         @default(false)
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  room              Room            @relation(fields: [roomId], references: [id])
  schoolYear        SchoolYear      @relation(fields: [schoolYearId], references: [id])
  section           Section         @relation(fields: [sectionId], references: [id])
  semester          Semester        @relation(fields: [semesterId], references: [id])
  subjectOffering   SubjectOffering @relation(fields: [subjectOfferingId], references: [id])
  teacher           Teacher         @relation(fields: [teacherId], references: [id])
}

model ScheduleRequest {
  id                  String        @id @default(uuid())
  teacherId           String
  teacher             Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectOfferingId   String
  subjectOffering     SubjectOffering @relation(fields: [subjectOfferingId], references: [id])
  sectionId           String
  section             Section       @relation(fields: [sectionId], references: [id])
  roomId              String?
  room                Room?         @relation(fields: [roomId], references: [id])
  dayOfWeek           String
  startTime           String
  endTime             String
  studentCount        Int           @default(0)
  notes               String?
  status              RequestStatus @default(PENDING)
  reviewedById        String?
  reviewedBy          User?         @relation(fields: [reviewedById], references: [id])
  reviewNotes         String?
  resultingScheduleId String?
  isDeleted           Boolean       @default(false)
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([teacherId, status])
  @@index([status, createdAt])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum RoleName {
  ADMINISTRATOR
  REGISTRAR_SCHEDULER
  CASHIER
  INSTRUCTOR
  STUDENT
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

enum FontSize {
  SMALL
  MEDIUM
  LARGE
}

enum PaymentType {
  TUITION_FEE
  MISCELLANEOUS
  LAB_FEE
  ENROLLMENT_FEE
  PARTIAL_PAYMENT
  ID_FEE
  OTHER
}

enum PaymentMethod {
  CASH
  GCASH
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum RoomType {
  LECTURE_ROOM
  COMPUTER_LABORATORY
  LABORATORY
  OFFICE
  CLINIC
  LIBRARY
  AVR
  SIMULATOR_ROOM
  FACULTY_ROOM
  UNAVAILABLE
}

enum ScheduleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  PENDING
  SCHEDULED
}
